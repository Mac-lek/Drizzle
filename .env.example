# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drizzle
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/drizzle

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-in-prod-too
JWT_REFRESH_TTL=30d

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_URL=https://api.drizzle.app/webhooks/paystack

# Dojah (KYC Tier 1)
DOJAH_APP_ID=xxx
DOJAH_PUBLIC_KEY=xxx
DOJAH_SECRET_KEY=xxx
DOJAH_BASE_URL=https://api.dojah.io

# Smile Identity (KYC Tier 2)
SMILE_PARTNER_ID=xxx
SMILE_API_KEY=xxx
SMILE_CALLBACK_URL=https://api.drizzle.app/webhooks/smile

# Termii (SMS)
TERMII_API_KEY=xxx
TERMII_SENDER_ID=Drizzle
TERMII_BASE_URL=https://api.ng.termii.com

# Firebase (Push)
FCM_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# Sentry
SENTRY_DSN=https://xxx.ingest.sentry.io/xxx

# Encryption (BVN at rest)
BVN_ENCRYPTION_KEY_ID=projects/xxx/locations/global/keyRings/xxx/cryptoKeys/bvn

# Process type (web | worker)
PROCESS_TYPE=web
